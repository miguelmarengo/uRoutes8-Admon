#!/usr/bin/env bash
# Prueba local con Flask sirviendo dist/ (build de Vite).
# 1) npm run build
# 2) ./run
# Puerto: PORT=8080 ./run
set -euo pipefail
cd "$(dirname "$0")"
ROOT="$(pwd)"
VENV="${VENV:-$ROOT/.venv-flask}"

if ! command -v python3 &>/dev/null; then
  echo "Necesitas python3 instalado."
  exit 1
fi

if [[ ! -d "$VENV" ]]; then
  python3 -m venv "$VENV"
fi
# shellcheck disable=SC1091
source "$VENV/bin/activate"
pip install -q -r "$ROOT/requirements-flask.txt"

export PORT="${PORT:-5000}"
exec python "$ROOT/serve_flask.py"
