# =============================================================================
# webAdmon — copia a .env.local y rellena (igual que en webOptimizador para Firebase).
# No subas .env.local al repo.
# =============================================================================

# Opcional: proyecto GCP (si no, deploy usa uroutes8; puedes usar cloudProject como en Optimizador)
# GCP_PROJECT_ID=uroutes8

# Firebase (mismo proyecto Admon / uRoutes8 que uses en Optimizador)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: token de 3 caracteres para altas/bajas de usuarios en el panel
VITE_TOKEN_ALTAS_BAJAS=

# Obligatorio para Firestore: mismo usuario Email/Password creado en Firebase Console (Authentication).
# Tras el login gaby/maria/mm el cliente hace signInWithEmailAndPassword con estos datos.
VITE_FIREBASE_PANEL_EMAIL=
VITE_FIREBASE_PANEL_PASSWORD=
