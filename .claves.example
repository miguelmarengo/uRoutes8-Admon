# Copia este archivo a .env.local (o usa .env.local.example)
# No subas .env.local ni .claves a git
# Mismos VITE_FIREBASE_* que webOptimizador/.env.local para el proyecto Admon.

# Firebase (proyecto uRoutes8 / Admon)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Token de 3 caracteres alfanuméricos para dar de alta o baja usuarios (ej: A1b)
VITE_TOKEN_ALTAS_BAJAS=

# Login del panel: usuarios en src/lib/admonHardcodedAuth.js + Firebase Auth para Firestore:
VITE_FIREBASE_PANEL_EMAIL=
VITE_FIREBASE_PANEL_PASSWORD=
