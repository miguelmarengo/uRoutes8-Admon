# =============================================================================
# webAdmon — opcional: copia a .env.deploy (no se sube a git).
# Mismos nombres que webOptimizador (cloudProject / serviceName) para unificar.
# =============================================================================

# Obligatorio si no pones GCP_PROJECT_ID en .env.local
GCP_PROJECT_ID=uroutes8
# Alternativa (como en Optimizador):
# cloudProject=uroutes8

GCP_REGION=us-central1

# Nombre del servicio en Cloud Run
CLOUD_RUN_SERVICE=webadmon
# Alternativa:
# serviceName=webadmon

# Tras habilitar APIs la primera vez, sube el tiempo si ves errores transitorios (Optimizador usa 60)
API_PROPAGATION_SLEEP=30

# Forzar build en la nube aunque Docker funcione
# USE_CLOUD_BUILD=1

# (Avanzado) Otorgar a Cloud Build permiso de escritura en Artifact Registry (requiere rol Owner/Admin IAM)
# GRANT_CLOUD_BUILD_ARTIFACT_IAM=1
